  "evaluation_criteria": {
    "format_compliance": {
      "description": "Does output contain required fields?",
      "required_fields": ["room", "area", "container", "items"],
      "items_must_have": ["name"],
      "items_may_have": ["attributes", "notes", "color", "brand"]
    },
    "room_accuracy": {
      "description": "Did it correctly identify the room?",
      "scoring": {
        "exact_match": 1.0,
        "acceptable_alternative": 0.8,
        "wrong_but_close": 0.3,
        "completely_wrong": 0.0
      }
    },
    "item_recall": {
      "description": "What fraction of must_identify items were found?",
      "weight": 0.4
    },
    "item_precision": {
      "description": "What fraction of identified items are real?",
      "weight": 0.3,
      "penalize_hallucinations": true
    },
    "practical_utility": {
      "description": "Would this help someone find their stuff?",
      "weight": 0.3,
      "criteria": [
        "Item names are searchable/common terms",
        "Location is specific enough to navigate to",
        "No overly technical or verbose descriptions"
      ]
    }
  },

