# ChoraGraph Capture - Environment Variables
# Copy this file to .env.local and fill in your keys

# --- Required for photo analysis (default provider) ---
GEMINI_API_KEY=

# --- Required for audio transcription ---
OPENAI_API_KEY=

# --- Optional: alternative vision analysis provider ---
CLAUDE_API_KEY=

# --- Optional: large audio file uploads (>4MB) ---
# Required if recording sessions longer than ~1 minute
BLOB_READ_WRITE_TOKEN=

# --- Optional: Neo4j graph database ---
# Only needed if using graph search features
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# --- Optional: app URL for launch API ---
# Falls back to request host header if not set
NEXT_PUBLIC_APP_URL=
